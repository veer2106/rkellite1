# RK Ellite Restaurant - Development Environment Template
# Copy to .env.dev and update DEV_EC2_IP before deploy

# Core App Config
NODE_ENV=development
PORT=5005

# Database (Dev)
DB_HOST=db
DB_PORT=5432
DB_NAME=restaurant_db_dev
DB_USER=cafe_user
DB_PASSWORD=dev_password_123

# Redis (Dev)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dev_redis_password
REDIS_URL=redis://dev_redis_password@redis:6379

# URLs (Update with your DEV_EC2_IP)
API_URL=http://YOUR_DEV_EC2_IP:5005
FRONTEND_URL=http://YOUR_DEV_EC2_IP:3002
CLIENT_URL=http://YOUR_DEV_EC2_IP:3002

# JWT (Dev - CHANGE before prod)
JWT_SECRET=dev_jwt_secret_super_long_and_secure_please_change
JWT_EXPIRE=7d

# Logging & Features
LOG_LEVEL=debug
ENABLE_PAYMENT=false
ENABLE_NOTIFICATIONS=true

# Optional Integrations (leave blank for dev)
STRIPE_SECRET_KEY=
SMTP_HOST=
SMTP_USER=

# AWS Region (if used)
AWS_REGION=ap-south-1
