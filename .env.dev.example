# RK Ellite Restaurant - Development Environment (Dual deploy alongside prod)
# Copy to .env.dev and update YOUR_DOMAIN before deploy
# Used when running dev on same EC2 as prod (dev.YOUR_DOMAIN.com)

# Core App Config
NODE_ENV=development
PORT=5005

# Database (Dev - separate from prod)
DB_HOST=db
DB_PORT=5432
DB_NAME=restaurant_db_dev
DB_USER=cafe_user
DB_PASSWORD=dev_password_123

# Redis (Dev - separate from prod)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dev_redis_password
REDIS_URL=redis://dev_redis_password@redis:6379

# URLs - use dev subdomain (nginx routes dev.YOUR_DOMAIN.com to this stack)
API_URL=https://dev.YOUR_DOMAIN.com
FRONTEND_URL=https://dev.YOUR_DOMAIN.com
CLIENT_URL=https://dev.YOUR_DOMAIN.com

# JWT (Dev - CHANGE before prod)
JWT_SECRET=dev_jwt_secret_super_long_and_secure_please_change
JWT_EXPIRE=7d

# Logging & Features
LOG_LEVEL=debug
ENABLE_PAYMENT=false
ENABLE_NOTIFICATIONS=true

# Optional Integrations (leave blank for dev)
STRIPE_SECRET_KEY=
SMTP_HOST=
SMTP_USER=

# AWS Region (if used)
AWS_REGION=ap-south-1
