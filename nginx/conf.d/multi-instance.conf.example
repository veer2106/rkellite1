# Nginx config for multiple instances on same EC2
# Copy to /etc/nginx/conf.d/ and customize. Reload: sudo nginx -t && sudo systemctl reload nginx
#
# Option A: Route by port (users access http://domain:5001, http://domain:5002)
#           No extra nginx needed - containers expose ports directly.
#
# Option B: Route by subdomain (app1.domain.com -> instance1, app2.domain.com -> instance2)
#           Uncomment and adapt below.

# server {
#     listen 80;
#     server_name app1.yourdomain.com;
#     location / {
#         proxy_pass http://127.0.0.1:5001;
#         proxy_http_version 1.1;
#         proxy_set_header Upgrade $http_upgrade;
#         proxy_set_header Connection 'upgrade';
#         proxy_set_header Host $host;
#         proxy_set_header X-Real-IP $remote_addr;
#         proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#         proxy_set_header X-Forwarded-Proto $scheme;
#         proxy_cache_bypass $http_upgrade;
#     }
# }
# server {
#     listen 80;
#     server_name app2.yourdomain.com;
#     location / {
#         proxy_pass http://127.0.0.1:5002;
#         proxy_http_version 1.1;
