# Nginx config: Prod + Dev on SAME EC2 (same static IP)
# Copy to /etc/nginx/conf.d/ on EC2, update DOMAIN, then: sudo nginx -t && sudo systemctl reload nginx
#
# DNS: Add A record for dev.YOUR_DOMAIN.com -> same EC2 static IP
# SSL: Add dev.YOUR_DOMAIN.com to certbot: sudo certbot certonly --nginx -d dev.YOUR_DOMAIN.com

# ============ PRODUCTION ============
# app.YOUR_DOMAIN.com, api.YOUR_DOMAIN.com -> prod (api serves both on 5001)

server {
    listen 80;
    server_name YOUR_DOMAIN.com www.YOUR_DOMAIN.com app.YOUR_DOMAIN.com api.YOUR_DOMAIN.com;

    # API -> prod backend
    location /api/ {
        proxy_pass http://127.0.0.1:5001/api/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Frontend -> prod
    location / {
        proxy_pass http://127.0.0.1:5001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
}

# ============ DEVELOPMENT ============
# dev.YOUR_DOMAIN.com -> dev (ports 5005, 3002)

server {
    listen 80;
    server_name dev.YOUR_DOMAIN.com dev-app.YOUR_DOMAIN.com;

    # API -> dev backend
    location /api/ {
        proxy_pass http://127.0.0.1:5005/api/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Frontend -> dev (Vite/CRA dev server)
    location / {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
    }
}

