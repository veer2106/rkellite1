# Install on EC2 host (not in Docker):
#   sudo cp nginx/nginx.host-no-docker.conf.example /etc/nginx/conf.d/rkellite.conf
#   sudo nginx -t && sudo systemctl reload nginx
#
# Proxies HTTP → Node app on 127.0.0.1:5001 (API + React static from same process)
#
# IMPORTANT: Remove the distro default site or this must be default_server, or you get
# Fedora/nginx /usr/share/nginx/html/404.html instead of your app:
#   sudo rm -f /etc/nginx/conf.d/default.conf

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    # Verify in browser DevTools → Network → Response headers (confirms this proxy, not stock nginx)
    add_header X-RKellite-Proxy "1" always;

    # Open in browser: http://YOUR_IP/rkellite-nginx-check — must show exactly: RKELLITE_NGINX_OK
    # If you see the nginx welcome page on / but this works, you have a cache/CDN issue.
    location = /rkellite-nginx-check {
        default_type text/plain;
        return 200 "RKELLITE_NGINX_OK\n";
    }

    client_max_body_size 50M;

    location /api/ {
        proxy_pass http://127.0.0.1:5001/api/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    location /socket.io/ {
        proxy_pass http://127.0.0.1:5001/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
    }

    location / {
        proxy_pass http://127.0.0.1:5001/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
