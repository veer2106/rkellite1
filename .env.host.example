# Copy to .env on the server (native / no Docker)
# PostgreSQL on localhost — create DB and user first (see docs/deployment/DEPLOY_HOST_NO_DOCKER.md)

NODE_ENV=production
PORT=5001

DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurant_db
DB_USER=cafe_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Same origin as your site (Nginx → Node on 5001)
FRONTEND_URL=http://localhost:5001
API_URL=http://localhost:5001
CLIENT_URL=http://YOUR_DOMAIN_OR_IP

JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRE=7d

# Optional
LOG_LEVEL=info
