# Instance 2 - Copy to .env.instance2 and customize
INSTANCE_ID=2
DOCKER_IMAGE=restaurant-cafe:instance2

# Ports (host-facing - must be unique per instance)
API_PORT=5002
DB_HOST_PORT=5433
REDIS_HOST_PORT=6380

# Database - unique per instance
DB_NAME=restaurant_db_2
DB_USER=cafe_user
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_change_me_instance2
JWT_EXPIRE=7d

# URLs
FRONTEND_URL=http://YOUR_EC2_IP:5002
API_URL=http://YOUR_EC2_IP:5002

# Frontend build
REACT_APP_API_URL=/api
