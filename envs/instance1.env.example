# Instance 1 - Copy to .env.instance1 and customize
INSTANCE_ID=1
DOCKER_IMAGE=restaurant-cafe:instance1

# Ports (host-facing - must be unique per instance)
API_PORT=5001
DB_HOST_PORT=5432
REDIS_HOST_PORT=6379

# Database - unique per instance
DB_NAME=restaurant_db_1
DB_USER=cafe_user
DB_PASSWORD=your_secure_password_here

# Redis (no password for simplicity - add --requirepass if needed)
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_change_me_instance1
JWT_EXPIRE=7d

# URLs (for CORS, redirects - use EC2 IP or domain)
FRONTEND_URL=http://YOUR_EC2_IP:5001
API_URL=http://YOUR_EC2_IP:5001
# When using Nginx with subdomains:
# FRONTEND_URL=https://app1.yourdomain.com
# API_URL=https://api1.yourdomain.com

# Frontend build - API base URL (use /api for same-origin, or full URL)
REACT_APP_API_URL=/api
